{
  "statusLine": {
    "type": "command",
    "command": "~/.claude/scripts/statusline.sh",
    "padding": 0
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "./.claude/hooks/enforce-git-pull-rebase.sh"
          }
        ]
      },
      {
        "matcher": "mcp__ide__getDiagnostics",
        "hooks": [
          {
            "type": "command",
            "command": "./.claude/hooks/open-file-in-ide.sh"
          }
        ]
      },
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "./.claude/hooks/refresh-usage-cache.sh"
          }
        ]
      },
      {
        "matcher": "mcp__brave-search__.*",
        "hooks": [
          {
            "type": "command",
            "command": "./.claude/hooks/rate-limit-brave-search.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "./.claude/hooks/refresh-usage-cache.sh"
          }
        ]
      }
    ]
  }
}

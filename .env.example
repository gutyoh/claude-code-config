# claude-code-config/.env.example
#
# Copy this file to .env and fill in your values.
# The .env file is gitignored and will NOT be committed.
#
# =============================================================================
# QUICK START BY PLATFORM
# =============================================================================
#
# macOS / Linux / WSL:
#   cp .env.example .env
#   nano .env                    # Edit with your values
#   cp .envrc.example .envrc
#   direnv allow                 # Auto-load on cd
#   # OR: source .env            # Manual one-time load
#
# Windows (Git Bash):
#   cp .env.example .env
#   nano .env                    # Edit with your values
#   cp .envrc.example .envrc
#   direnv allow                 # If direnv installed
#   # OR: source .env            # Manual one-time load
#   # OR: export $(grep -v '^#' .env | xargs)
#
# Windows (PowerShell):
#   Copy-Item .env.example .env
#   notepad .env                 # Edit with your values
#   # Then load with:
#   Get-Content .env | ForEach-Object {
#     if ($_ -match '^([^#][^=]+)=(.*)$') {
#       [Environment]::SetEnvironmentVariable($matches[1], $matches[2], 'Process')
#     }
#   }
#
# Windows (CMD):
#   copy .env.example .env
#   notepad .env                 # Edit with your values
#   # Then manually set each variable:
#   set BRAVE_API_KEY=your-key-here
#
# =============================================================================
# MCP Server: Brave Search
# =============================================================================
# Required for internet search capabilities via the brave-search MCP server.
# Get your free API key (1,000 searches/month, $5 free credits): https://api-dashboard.search.brave.com/
BRAVE_API_KEY=your-brave-api-key-here

# =============================================================================
# MCP Server: Tavily
# =============================================================================
# AI-native search, extract, crawl, map, and research via Tavily API.
# Get your free API key (1,000 credits/month): https://tavily.com
TAVILY_API_KEY=your-tavily-api-key-here

# =============================================================================
# Key Rotation Pools (optional, for mcp-key-rotate)
# =============================================================================
# Comma-separated list of all keys for each service.
# Used by bin/mcp-key-rotate to rotate the active key.
# If using Doppler, these are managed there instead.
# BRAVE_API_KEY_POOL=key1,key2
# TAVILY_API_KEY_POOL=key1,key2,key3

# =============================================================================
# Future MCP Servers (add as needed)
# =============================================================================
# GITHUB_TOKEN=your-github-token
# OPENAI_API_KEY=your-openai-key
# DATABASE_URL=postgresql://user:pass@host:5432/db

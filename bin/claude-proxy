#!/usr/bin/env bash
set -euo pipefail

# claude-proxy
# Path: bin/claude-proxy
#
# Run Claude Code against a local proxy, optionally starting it if not reachable.
#
# This is intentionally *not* coupled to a single provider.
# - "profiles" control how to start the proxy (auth import, config, etc.)
# - model selection is validated per profile and passed to Claude via env defaults
#
# Usage:
#   ./bin/claude-proxy [options] [--] [claude args...]
#
# Options:
#   -m, --model MODEL        Model string (validated per profile; uses profile default if omitted)
#   -p, --profile PROFILE    Proxy profile: codex | antigravity | none (default: codex)
#   --models                 List available models for the selected profile and exit
#   --host HOST              Proxy host (default: 127.0.0.1)
#   --port PORT              Proxy port (auto-set per profile if omitted)
#   --api-key KEY            Proxy API key (auto-set per profile if omitted)
#   --no-start               Require proxy to be already running (skip auto-start)
#   --no-validate            Skip model validation
#   -h, --help               Show help
#
# Custom profiles:
#   Provide an executable script at: bin/proxy-start-<profile>.sh
#   It should start the proxy in the foreground (the launcher handles backgrounding).
#
# Examples:
#   ./bin/claude-proxy                                             # codex default
#   ./bin/claude-proxy -m 'gpt-5.3-codex(medium)'                 # codex + medium effort
#   ./bin/claude-proxy -p antigravity                              # antigravity default
#   ./bin/claude-proxy -p antigravity -m 'gemini-3-pro-high[1m]'  # antigravity + gemini
#   ./bin/claude-proxy -p antigravity --models                     # list antigravity models
#   ./bin/claude-proxy --no-start -m 'claude-opus-4-6'            # external proxy

# --- Model Registry ---

# Model discovery order:
#   1. Live /v1/models from a running proxy (fetch_proxy_models, lib/proxy)
#   2. Offline: read ${CLI_PROXY_DIR}/internal/registry/models/models.json
#      directly. This is CLIProxyAPI's own registry and is always current
#      with whatever version you have checked out.
# No static fallback — the repo clone is the source of truth offline.

readonly ANTIGRAVITY_DEFAULT="claude-opus-4-6-thinking"
readonly CODEX_DEFAULT="gpt-5.3-codex(high)"
# Effort levels accepted by CLIProxyAPI's thinking suffix parser.
readonly CODEX_EFFORTS=("minimal" "low" "medium" "high" "xhigh")

# --- Helpers ---

need_cmd() {
    command -v "$1" >/dev/null 2>&1 || {
        echo "Missing required command: $1" >&2
        exit 1
    }
}

usage() {
    cat <<'EOF'
claude-proxy — Run Claude Code against a local proxy

Usage: claude-proxy [options] [--] [claude args...]

Options:
  -m, --model MODEL        Model string (validated per profile; uses profile default if omitted)
  -p, --profile PROFILE    Proxy profile: codex | antigravity | none (default: codex)
  --models                 List available models for the selected profile and exit
  --host HOST              Proxy host (default: 127.0.0.1)
  --port PORT              Proxy port (auto-set per profile if omitted)
  --api-key KEY            Proxy API key (auto-set per profile if omitted)
  --no-start               Require proxy to be already running (skip auto-start)
  --no-validate            Skip model validation
  -h, --help               Show this help message

Custom profiles:
  Provide an executable script at: bin/proxy-start-<profile>.sh
  It should start the proxy in the foreground (the launcher handles backgrounding).

Examples:
  claude-proxy                                             # codex default
  claude-proxy -m 'gpt-5.3-codex(medium)'                  # codex + medium effort
  claude-proxy -p antigravity                              # antigravity default
  claude-proxy -p antigravity -m 'gemini-3-pro-high[1m]'   # antigravity + gemini
  claude-proxy -p antigravity --models                     # list antigravity models
  claude-proxy --no-start -m 'claude-opus-4-6'             # external proxy
EOF
}

_in_array() {
    local needle="$1"
    shift
    local item
    for item in "$@"; do
        [[ "${item}" == "${needle}" ]] && return 0
    done
    return 1
}

# Read the list of model IDs for a profile directly from CLIProxyAPI's
# registry file. Prints one ID per line on success; returns 1 if the file
# is missing, unreadable, or contains an unknown profile.
#
# Args: $1 = profile (codex|antigravity)
#       $2 = CLIProxyAPI repo root (defaults to $CLI_PROXY_DIR)
fetch_offline_models() {
    local profile="$1"
    local repo="${2:-${CLI_PROXY_DIR:-}}"
    [[ -n "${repo}" ]] || return 1
    local models_json="${repo}/internal/registry/models/models.json"
    [[ -r "${models_json}" ]] || return 1

    local jq_filter
    case "${profile}" in
        codex)
            # Union across all Codex plan tiers so the user's plan doesn't matter
            jq_filter='[.["codex-free"]?, .["codex-plus"]?, .["codex-pro"]?, .["codex-team"]?] | map(.[]? | .id) | unique | .[]'
            ;;
        antigravity)
            jq_filter='.antigravity[]? | .id'
            ;;
        *)
            return 1
            ;;
    esac

    local out
    out=$(jq -r "${jq_filter}" "${models_json}" 2>/dev/null) || return 1
    [[ -n "${out}" ]] || return 1
    echo "${out}"
}

list_models() {
    local profile="$1"
    local proxy_url="${2:-}"

    # Tier 1: live discovery from running proxy
    if [[ -n "${proxy_url}" ]]; then
        local live_models
        if live_models=$(fetch_proxy_models "${proxy_url}"); then
            echo "Available models for profile '${profile}' (live from proxy):"
            echo ""
            while IFS= read -r model_id; do
                echo "  ${model_id}"
            done <<<"${live_models}"
            echo ""
            case "${profile}" in
                antigravity)
                    echo "  Gemini models accept an optional context window suffix: model[1m]"
                    echo "  Default: ${ANTIGRAVITY_DEFAULT}"
                    ;;
                codex)
                    echo "  Format: model(effort)  e.g. gpt-5.3-codex(high)"
                    echo "  Default: ${CODEX_DEFAULT}"
                    ;;
            esac
            return 0
        fi
    fi

    # Tier 2: offline — read CLIProxyAPI's registry file directly
    local offline_models
    if offline_models=$(fetch_offline_models "${profile}"); then
        echo "Available models for profile '${profile}' (offline — from CLIProxyAPI registry):"
        echo ""
        while IFS= read -r model_id; do
            echo "  ${model_id}"
        done <<<"${offline_models}"
        echo ""
        case "${profile}" in
            antigravity)
                echo "  Gemini models accept an optional context window suffix: model[1m]"
                echo "  Default: ${ANTIGRAVITY_DEFAULT}"
                ;;
            codex)
                echo "  Format: model(effort)  e.g. gpt-5.3-codex(high)"
                echo "  Valid efforts: ${CODEX_EFFORTS[*]}"
                echo "  Default: ${CODEX_DEFAULT}"
                ;;
        esac
        return 0
    fi

    # Tier 3: nothing works — tell the user what to do
    echo "Cannot list models for profile '${profile}':"
    echo "  Proxy not reachable at ${proxy_url:-<no proxy>}"
    echo "  CLIProxyAPI registry not found at \${CLI_PROXY_DIR}/internal/registry/models/models.json"
    echo ""
    echo "  Start the proxy (./bin/claude-proxy without --no-start), or"
    echo "  clone CLIProxyAPI to \$CLI_PROXY_DIR (default: ~/Documents/dev/CLIProxyAPI)."
}

# Check if a base model name appears in either the live or the offline
# registry. Returns 0 if found, 1 if not found in ANY source.
_model_in_registry() {
    local base="$1" profile="$2" proxy_url="$3"

    # Live source wins if reachable
    if [[ -n "${proxy_url}" ]]; then
        local live
        if live=$(fetch_proxy_models "${proxy_url}" 2>/dev/null); then
            echo "${live}" | grep -qx "${base}" && return 0
            return 1
        fi
    fi

    # Offline fallback
    local offline
    if offline=$(fetch_offline_models "${profile}" 2>/dev/null); then
        echo "${offline}" | grep -qx "${base}" && return 0
        return 1
    fi

    return 1
}

validate_model() {
    local model="$1"
    local profile="$2"
    local proxy_url="${3:-}"

    case "${profile}" in
        antigravity)
            # Strip optional [context] suffix: gemini-3-pro-high[1m] → gemini-3-pro-high
            local base="${model%%\[*}"
            if ! _model_in_registry "${base}" "${profile}" "${proxy_url}"; then
                echo "Error: unknown model '${model}' for profile '${profile}'." >&2
                echo "  Use --no-validate to bypass (e.g. for newly added models)." >&2
                echo "" >&2
                list_models "${profile}" "${proxy_url}" >&2
                return 1
            fi
            ;;
        codex)
            local base="" effort=""
            if [[ "${model}" =~ ^([^(]+)\(([^)]+)\)$ ]]; then
                base="${BASH_REMATCH[1]}"
                effort="${BASH_REMATCH[2]}"
            else
                base="${model}"
            fi

            if ! _model_in_registry "${base}" "${profile}" "${proxy_url}"; then
                echo "Error: unknown model '${base}' for profile '${profile}'." >&2
                echo "  Use --no-validate to bypass (e.g. for newly added models)." >&2
                echo "" >&2
                list_models "${profile}" "${proxy_url}" >&2
                return 1
            fi

            # Effort validation — the registry exposes per-model levels but
            # CLIProxyAPI's thinking suffix parser also accepts minimal.
            # Validating against CODEX_EFFORTS (the superset) is safe.
            if [[ -n "${effort}" ]]; then
                if ! _in_array "${effort}" "${CODEX_EFFORTS[@]}"; then
                    echo "Error: unknown effort level '${effort}'." >&2
                    echo "  Valid levels: ${CODEX_EFFORTS[*]}" >&2
                    return 1
                fi
            fi
            ;;
        *)
            # No validation for custom/unknown profiles
            ;;
    esac
}

# --- Init ---

need_cmd claude
need_cmd curl
need_cmd nohup

# Resolve this script's real path through any chain of symlinks so that
# $ROOT_DIR always points at the claude-code-config repo, even when the
# script is invoked via ~/.local/bin/claude-proxy (Unix symlink) or via a
# Windows shim that re-execs this file. Portable: does not require
# `readlink -f` (absent from BSD readlink on older macOS and Git Bash).
_resolve_self() {
    local src="${BASH_SOURCE[0]}"
    while [[ -L "$src" ]]; do
        local dir
        dir="$(cd -P "$(dirname "$src")" && pwd)"
        src="$(readlink "$src")"
        [[ "$src" != /* ]] && src="$dir/$src"
    done
    (cd -P "$(dirname "$src")" && pwd)
}
_SCRIPT_DIR="$(_resolve_self)"
ROOT_DIR="$(cd -P "${_SCRIPT_DIR}/.." && pwd)"
readonly ROOT_DIR

source "${ROOT_DIR}/lib/proxy/preflight.sh"

HOST="127.0.0.1"
PORT=""
PORT_EXPLICIT="false"
API_KEY="sk-dummy"
MODEL=""
PROFILE="codex"
NO_START="false"
SHOW_MODELS="false"
NO_VALIDATE="false"

# CLIProxyAPI repo location — used for offline model registry lookup and
# inherited by profile scripts (proxy-start-*.sh) that need to build or
# exec the binary. Override via env: `CLI_PROXY_DIR=/path/to/repo ...`
export CLI_PROXY_DIR="${CLI_PROXY_DIR:-$HOME/Documents/dev/CLIProxyAPI}"

# --- Args ---
while [[ $# -gt 0 ]]; do
    case "$1" in
        -m | --model)
            MODEL="${2:-}"
            shift 2
            ;;
        -p | --profile)
            PROFILE="${2:-}"
            shift 2
            ;;
        --models)
            SHOW_MODELS="true"
            shift
            ;;
        --host)
            HOST="${2:-}"
            shift 2
            ;;
        --port)
            PORT="${2:-}"
            PORT_EXPLICIT="true"
            shift 2
            ;;
        --api-key)
            API_KEY="${2:-}"
            shift 2
            ;;
        --no-start)
            NO_START="true"
            shift
            ;;
        --no-validate)
            NO_VALIDATE="true"
            shift
            ;;
        -h | --help)
            usage
            exit 0
            ;;
        --)
            shift
            break
            ;;
        *)
            break
            ;;
    esac
done

# --- Per-profile defaults ---

# PORT and API_KEY defaults must be set before --models so the proxy URL
# can be constructed for live /v1/models queries.
if [[ "${PORT_EXPLICIT}" == "false" ]]; then
    case "${PROFILE}" in
        antigravity) PORT="8081" ;;
        *) PORT="8317" ;;
    esac
fi
if [[ "${API_KEY}" == "sk-dummy" ]]; then
    case "${PROFILE}" in
        antigravity) API_KEY="test" ;;
        *) ;;
    esac
fi

if [[ "${SHOW_MODELS}" == "true" ]]; then
    list_models "${PROFILE}" "http://${HOST}:${PORT}"
    exit 0
fi

# Default model per profile (when -m is not provided)
if [[ -z "${MODEL}" ]]; then
    case "${PROFILE}" in
        antigravity) MODEL="${ANTIGRAVITY_DEFAULT}" ;;
        codex) MODEL="${CODEX_DEFAULT}" ;;
        *) ;;
    esac
fi

# Validate model against profile's known models
if [[ -n "${MODEL}" && "${NO_VALIDATE}" == "false" ]]; then
    validate_model "${MODEL}" "${PROFILE}" "http://${HOST}:${PORT}" || exit 1
fi

# --- Preflight: codex token freshness ---
if [[ "${PROFILE}" == "codex" ]]; then
    _codex_auth="${HOME}/.codex/auth.json"
    if [[ -f "$_codex_auth" ]]; then
        check_codex_token_freshness "$_codex_auth" "${CODEX_TOKEN_MAX_AGE_HOURS:-48}" || true
    fi
fi

proxy_url="http://${HOST}:${PORT}"
readonly proxy_url

# --- Proxy lifecycle ---

is_proxy_up() {
    curl -s --max-time 0.2 -o /dev/null "$proxy_url/" 2>/dev/null || return 1
}

start_proxy_bg() {
    local start_script=""

    case "${PROFILE}" in
        codex)
            start_script="${ROOT_DIR}/bin/proxy-start-codex.sh"
            ;;
        none)
            echo "Profile 'none' cannot start the proxy." >&2
            return 1
            ;;
        *)
            start_script="${ROOT_DIR}/bin/proxy-start-${PROFILE}.sh"
            ;;
    esac

    if [[ ! -x "${start_script}" ]]; then
        echo "Start script not found or not executable: ${start_script}" >&2
        echo "Either use --no-start, or create bin/proxy-start-${PROFILE}.sh" >&2
        return 1
    fi

    local proxy_log
    proxy_log="${PROXY_LOG:-$HOME/.cli-proxy-api/cli-proxy-api.log}"
    mkdir -p "$(dirname "${proxy_log}")"

    HOST="${HOST}" \
        PORT="${PORT}" \
        API_KEY="${API_KEY}" \
        MODEL="${MODEL:-}" \
        CLI_PROXY_DIR="${CLI_PROXY_DIR:-}" \
        nohup "${start_script}" >"${proxy_log}" 2>&1 &
}

if ! is_proxy_up; then
    if [[ "${NO_START}" == "true" ]]; then
        echo "Proxy not reachable at ${proxy_url} (and --no-start was set)." >&2
        exit 1
    fi

    echo "Proxy not reachable at ${proxy_url} — starting (profile=${PROFILE})..." >&2
    start_proxy_bg

    for _ in {1..50}; do
        if is_proxy_up; then
            break
        fi
        sleep 0.1
    done

    if ! is_proxy_up; then
        echo "Proxy still not reachable at ${proxy_url}." >&2
        echo "Check logs: ${PROXY_LOG:-$HOME/.cli-proxy-api/cli-proxy-api.log}" >&2
        exit 1
    fi
fi

# --- Session verification (antigravity) ---
if [[ "${PROFILE}" == "antigravity" ]]; then
    if ! test_antigravity_session "${proxy_url}" "${API_KEY}" "${MODEL}"; then
        echo "" >&2
        echo "Antigravity session expired or no Google account linked." >&2
        echo "" >&2
        open_url "${proxy_url}"
        echo "Re-authenticate in your browser:" >&2
        echo "  1. Go to Accounts → add or re-add your Google account" >&2
        echo "  2. Complete Google OAuth" >&2
        echo "  3. Return here and press Enter" >&2
        echo "" >&2
        read -r -p "Press Enter when done (Ctrl+C to abort)... "

        if ! test_antigravity_session "${proxy_url}" "${API_KEY}" "${MODEL}"; then
            echo "Session still invalid. Check ${proxy_url} and try again." >&2
            exit 1
        fi
        echo "Session verified — launching Claude Code." >&2
    fi
fi

# --- Run Claude ---
if [[ -n "${MODEL}" ]]; then
    ANTHROPIC_BASE_URL="${proxy_url}" \
        ANTHROPIC_AUTH_TOKEN="${API_KEY}" \
        ANTHROPIC_DEFAULT_OPUS_MODEL="${MODEL}" \
        ANTHROPIC_DEFAULT_SONNET_MODEL="${MODEL}" \
        ANTHROPIC_DEFAULT_HAIKU_MODEL="${MODEL}" \
        exec claude "$@"
else
    ANTHROPIC_BASE_URL="${proxy_url}" \
        ANTHROPIC_AUTH_TOKEN="${API_KEY}" \
        exec claude "$@"
fi

#!/usr/bin/env bash
# mcp-key-rotate
# Path: claude-code-config/bin/mcp-key-rotate
#
# API key rotation for MCP servers (Brave Search, Tavily, etc.).
# Auto-detects backend: Doppler → .env file.
#
# Usage:
#   mcp-key-rotate <service>                   # Rotate to next HEALTHY key in pool
#   mcp-key-rotate <service> --status          # Show current key and pool
#   mcp-key-rotate <service> --health          # Show circuit state per key
#   mcp-key-rotate <service> --quota           # Show per-key credit usage (live API check)
#   mcp-key-rotate <service> --mark-bad [TTL]  # Mark current key OPEN for TTL seconds
#   mcp-key-rotate <service> --mark-good       # Mark current key CLOSED (clear circuit)
#   mcp-key-rotate <service> --reset-health    # Clear all circuit state for service
#   mcp-key-rotate <service> --add KEY         # Add a new key to the pool
#
# Circuit breaker: each key is CLOSED / OPEN / HALF_OPEN. Rotation skips OPEN
# keys; if all are OPEN it picks the one with the soonest open_until. Health
# state at ${MCP_KEY_HEALTH_DIR}/<service>.json, keyed by sha256(key)[:12] so
# raw keys never hit disk.
#
# Services: brave, tavily (or any MCP service with {SERVICE}_API_KEY vars)
# Backends: doppler (auto-detected), dotenv (.env file)
# Overrides:
#   KEY_ROTATE_BACKEND=doppler|dotenv
#   MCP_KEY_HEALTH_DIR (default: ~/.claude/state)
#
# Requires: doppler CLI or .env file, plus jq.

set -euo pipefail

# --- Config ---
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
readonly SCRIPT_DIR
REPO_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"
readonly REPO_ROOT
readonly DOTENV_FILE="${KEY_ROTATE_DOTENV:-${REPO_ROOT}/.env}"
readonly DOPPLER_PROJECT="${KEY_ROTATE_DOPPLER_PROJECT:-claude-code-config}"
readonly DOPPLER_CONFIG="${KEY_ROTATE_DOPPLER_CONFIG:-dev}"

readonly HEALTH_DIR="${MCP_KEY_HEALTH_DIR:-${HOME}/.claude/state}"
# 1h default TTL: short enough for transient 429s to recover, long enough to
# avoid re-probing monthly-quota-exhausted keys on every hook fire.
readonly HEALTH_DEFAULT_TTL_SEC="${MCP_KEY_HEALTH_DEFAULT_TTL_SEC:-3600}"

# --- Parse service argument ---
SERVICE="${1:-}"
if [[ -z "${SERVICE}" || "${SERVICE}" == --* ]]; then
    echo "Usage: mcp-key-rotate <service> [--status|--add KEY|--help]"
    echo ""
    echo "Services: brave, tavily (or any MCP service with {SERVICE}_API_KEY vars)"
    echo "Backends: doppler (auto-detected), dotenv (.env file)"
    echo "Override: KEY_ROTATE_BACKEND=doppler|dotenv"
    exit 1
fi
shift

# Normalize to uppercase for variable names
SERVICE_UPPER="$(echo "${SERVICE}" | tr '[:lower:]' '[:upper:]')"
readonly KEY_VAR="${SERVICE_UPPER}_API_KEY"
readonly POOL_VAR="${SERVICE_UPPER}_API_KEY_POOL"

# --- Backend: Doppler ---
doppler_get() {
    doppler secrets get "$1" --plain -p "${DOPPLER_PROJECT}" -c "${DOPPLER_CONFIG}" 2>/dev/null
}

doppler_set() {
    doppler secrets set "$1=$2" -p "${DOPPLER_PROJECT}" -c "${DOPPLER_CONFIG}" >/dev/null
}

# --- Backend: dotenv ---
dotenv_get() {
    local var="$1"
    # Try the .env file first
    if [[ -f "${DOTENV_FILE}" ]]; then
        local val
        val="$(grep "^${var}=" "${DOTENV_FILE}" 2>/dev/null | head -1 | cut -d'=' -f2-)"
        if [[ -n "${val}" ]]; then
            echo "${val}"
            return
        fi
    fi
    # Fallback: read from current environment
    echo "${!var:-}"
}

dotenv_set() {
    local var="$1" val="$2"
    if [[ -f "${DOTENV_FILE}" ]] && grep -q "^${var}=" "${DOTENV_FILE}" 2>/dev/null; then
        # awk replacement: no delimiter risk (sed delimiters can clash with key values)
        local tmp="${DOTENV_FILE}.tmp.$$"
        awk -v name="${var}" -v value="${val}" \
            'BEGIN{FS=OFS="="} $1==name{$0=name"="value} {print}' \
            "${DOTENV_FILE}" >"${tmp}" && mv "${tmp}" "${DOTENV_FILE}"
    else
        # Append new entry
        echo "${var}=${val}" >>"${DOTENV_FILE}"
    fi
}

# --- Backend detection ---
detect_backend() {
    local requested="${KEY_ROTATE_BACKEND:-auto}"

    if [[ "${requested}" != "auto" ]]; then
        echo "${requested}"
        return
    fi

    # Tier 1: Doppler CLI available and project configured
    if command -v doppler &>/dev/null; then
        if doppler secrets get "${KEY_VAR}" --plain -p "${DOPPLER_PROJECT}" -c "${DOPPLER_CONFIG}" &>/dev/null; then
            echo "doppler"
            return
        fi
    fi

    # Tier 2: .env file with pool variable
    if [[ -f "${DOTENV_FILE}" ]] && grep -q "^${POOL_VAR}=" "${DOTENV_FILE}" 2>/dev/null; then
        echo "dotenv"
        return
    fi

    # Tier 3: Pool variable in environment (can read, will write to .env)
    if [[ -n "${!POOL_VAR:-}" ]]; then
        echo "dotenv"
        return
    fi

    echo ""
}

BACKEND="$(detect_backend)"
if [[ -z "${BACKEND}" ]]; then
    echo "Error: No backend available for service '${SERVICE}'."
    echo ""
    echo "Options:"
    echo "  1. Install doppler CLI and run: doppler setup"
    echo "  2. Add to ${DOTENV_FILE}:"
    echo "       ${KEY_VAR}=your-active-key"
    echo "       ${POOL_VAR}=key1,key2"
    echo ""
    echo "Override: KEY_ROTATE_BACKEND=doppler|dotenv"
    exit 1
fi

# --- Unified read/write ---
secret_get() {
    case "${BACKEND}" in
        doppler) doppler_get "$1" ;;
        dotenv) dotenv_get "$1" ;;
        *)
            echo "Unknown backend: ${BACKEND}" >&2
            exit 1
            ;;
    esac
}

secret_set() {
    case "${BACKEND}" in
        doppler) doppler_set "$1" "$2" ;;
        dotenv) dotenv_set "$1" "$2" ;;
        *)
            echo "Unknown backend: ${BACKEND}" >&2
            exit 1
            ;;
    esac
}

# --- MCP keys env file sync ---
# When using the dotenv backend, also update ~/.claude/mcp-keys.env
# so the mcp-env-inject wrapper picks up the new key on next MCP restart.
readonly MCP_KEYS_ENV_FILE="${MCP_KEYS_ENV_FILE:-${HOME}/.claude/mcp-keys.env}"

sync_mcp_keys_env() {
    # Only sync for dotenv backend (Doppler injects keys live at MCP launch)
    if [[ "${BACKEND}" == "doppler" ]]; then
        return
    fi

    if [[ ! -f "${MCP_KEYS_ENV_FILE}" ]]; then
        # No env file exists yet — nothing to sync
        return
    fi

    local current_key
    current_key="$(secret_get "${KEY_VAR}")"
    if [[ -z "${current_key}" ]]; then
        return
    fi

    # Update or append the key in the env file
    if grep -q "^${KEY_VAR}=" "${MCP_KEYS_ENV_FILE}" 2>/dev/null; then
        local tmp="${MCP_KEYS_ENV_FILE}.tmp.$$"
        awk -v name="${KEY_VAR}" -v value="${current_key}" \
            'BEGIN{FS=OFS="="} $1==name{$0=name"="value} {print}' \
            "${MCP_KEYS_ENV_FILE}" >"${tmp}" && mv "${tmp}" "${MCP_KEYS_ENV_FILE}"
    else
        echo "${KEY_VAR}=${current_key}" >>"${MCP_KEYS_ENV_FILE}"
    fi
    chmod 600 "${MCP_KEYS_ENV_FILE}"
    echo "Synced ${KEY_VAR} to ${MCP_KEYS_ENV_FILE}"
}

cmd_sync() {
    # Explicitly sync all known MCP keys to the env file
    local current_key
    current_key="$(secret_get "${KEY_VAR}")"

    if [[ -z "${current_key}" ]]; then
        echo "No active key found for ${SERVICE} (${KEY_VAR})."
        exit 1
    fi

    mkdir -p "$(dirname "${MCP_KEYS_ENV_FILE}")"

    if [[ -f "${MCP_KEYS_ENV_FILE}" ]] && grep -q "^${KEY_VAR}=" "${MCP_KEYS_ENV_FILE}" 2>/dev/null; then
        local tmp="${MCP_KEYS_ENV_FILE}.tmp.$$"
        awk -v name="${KEY_VAR}" -v value="${current_key}" \
            'BEGIN{FS=OFS="="} $1==name{$0=name"="value} {print}' \
            "${MCP_KEYS_ENV_FILE}" >"${tmp}" && mv "${tmp}" "${MCP_KEYS_ENV_FILE}"
    else
        echo "${KEY_VAR}=${current_key}" >>"${MCP_KEYS_ENV_FILE}"
    fi
    chmod 600 "${MCP_KEYS_ENV_FILE}"
    echo "Synced ${SERVICE} key to ${MCP_KEYS_ENV_FILE} ($(mask_key "${current_key}"))"
}

# --- Helpers ---
mask_key() {
    local key="$1"
    if [[ ${#key} -lt 12 ]]; then
        echo "${key:0:3}***"
    else
        echo "${key:0:6}...${key: -4}"
    fi
}

# Key health state: ~/.claude/state/<service>.json, keyed by sha256(key)[:12].
# Raw keys never hit disk.

health_file() {
    echo "${HEALTH_DIR}/${SERVICE}.json"
}

key_fingerprint() {
    local key="$1"
    if command -v shasum &>/dev/null; then
        printf '%s' "${key}" | shasum -a 256 | cut -c1-12
    elif command -v sha256sum &>/dev/null; then
        printf '%s' "${key}" | sha256sum | cut -c1-12
    else
        printf '%s' "${key: -8}"
    fi
}

_health_read_field() {
    local key="$1" field="$2"
    local file fp
    file="$(health_file)"
    [[ -f "${file}" ]] || return 0
    fp="$(key_fingerprint "${key}")"
    jq -r --arg fp "${fp}" --arg f "${field}" \
        '.keys[$fp][$f] // empty' "${file}" 2>/dev/null || true
}

health_state() {
    local val
    val="$(_health_read_field "$1" "state")"
    echo "${val:-closed}"
}

health_open_until() {
    local val
    val="$(_health_read_field "$1" "open_until")"
    echo "${val:-0}"
}

# CLOSED or HALF_OPEN (open_until expired) => eligible.
health_is_eligible() {
    local key="$1" now state ou
    now="$(date +%s)"
    state="$(health_state "${key}")"
    if [[ "${state}" != "open" ]]; then
        return 0
    fi
    ou="$(health_open_until "${key}")"
    if [[ "${ou}" -le "${now}" ]]; then
        return 0
    fi
    return 1
}

# Atomic write via tmp+rename so readers never see a half-written doc.
_health_write_file() {
    local tmp="$1"
    local file
    file="$(health_file)"
    mkdir -p "$(dirname "${file}")"
    mv "${tmp}" "${file}"
    chmod 600 "${file}" 2>/dev/null || true
}

health_mark_open() {
    local key="$1" ttl_sec="$2" error_msg="${3:-}"
    local file fp now open_until tmp
    file="$(health_file)"
    fp="$(key_fingerprint "${key}")"
    now="$(date +%s)"
    open_until=$((now + ttl_sec))
    mkdir -p "$(dirname "${file}")"
    tmp="${file}.tmp.$$"

    if [[ -f "${file}" ]]; then
        jq --arg fp "${fp}" \
            --argjson ou "${open_until}" \
            --argjson now "${now}" \
            --arg em "${error_msg}" \
            '
            (.keys //= {}) |
            .keys[$fp] = (
                (.keys[$fp] // {}) + {
                    state: "open",
                    open_until: $ou,
                    consecutive_failures: (((.keys[$fp].consecutive_failures // 0) | tonumber) + 1),
                    ejection_count:       (((.keys[$fp].ejection_count       // 0) | tonumber) + 1),
                    last_error: $em,
                    last_error_at: $now
                }
            ) |
            .schema = 1 |
            .updated_at = $now
            ' "${file}" >"${tmp}"
    else
        jq -n \
            --arg fp "${fp}" \
            --argjson ou "${open_until}" \
            --argjson now "${now}" \
            --arg em "${error_msg}" \
            '{
                schema: 1,
                updated_at: $now,
                keys: {
                    ($fp): {
                        state: "open",
                        open_until: $ou,
                        consecutive_failures: 1,
                        ejection_count: 1,
                        last_error: $em,
                        last_error_at: $now
                    }
                }
            }' >"${tmp}"
    fi

    _health_write_file "${tmp}"
}

# Mark a key CLOSED (success path). Zeroes consecutive_failures; keeps ejection_count
# as historical signal.
health_mark_closed() {
    local key="$1"
    local file fp now tmp
    file="$(health_file)"
    fp="$(key_fingerprint "${key}")"
    now="$(date +%s)"

    [[ -f "${file}" ]] || return 0

    tmp="${file}.tmp.$$"
    jq --arg fp "${fp}" \
        --argjson now "${now}" \
        '
        (.keys //= {}) |
        .keys[$fp] = (
            (.keys[$fp] // {}) + {
                state: "closed",
                open_until: 0,
                consecutive_failures: 0
            }
        ) |
        .updated_at = $now
        ' "${file}" >"${tmp}"
    _health_write_file "${tmp}"
}

health_reset() {
    local file
    file="$(health_file)"
    rm -f "${file}"
}

# --- Quota cache ---
readonly QUOTA_CACHE_DIR="${MCP_KEY_ROTATE_CACHE_DIR:-/tmp/mcp-key-rotate-cache}"
readonly QUOTA_CACHE_TTL_SEC="${MCP_KEY_ROTATE_CACHE_TTL:-300}" # 5 minutes

quota_cache_key() {
    local key="$1"
    # Use last 8 chars as cache filename (avoids exposing full key)
    echo "${QUOTA_CACHE_DIR}/${SERVICE_UPPER}_${key: -8}"
}

quota_cache_read() {
    local cache_file="$1"
    if [[ -f "${cache_file}" ]]; then
        # Cache format: line 1 = epoch timestamp, line 2 = data
        local cached_epoch cached_data
        cached_epoch="$(head -1 "${cache_file}")"
        cached_data="$(tail -1 "${cache_file}")"
        # Validate epoch is numeric (protects against corrupt/old-format cache)
        if [[ "${cached_epoch}" =~ ^[0-9]+$ ]]; then
            local now
            now="$(date +%s)"
            local age=$((now - cached_epoch))
            if [[ ${age} -lt ${QUOTA_CACHE_TTL_SEC} ]]; then
                echo "${cached_data}"
                return 0
            fi
        fi
    fi
    return 1
}

quota_cache_write() {
    local cache_file="$1" data="$2"
    mkdir -p "${QUOTA_CACHE_DIR}"
    # Store epoch on line 1, data on line 2 (no stat needed for age check)
    printf '%s\n%s\n' "$(date +%s)" "${data}" >"${cache_file}"
}

# --- Quota providers ---
# Each returns: used,limit,reset_info  (or "error,message" on failure)

quota_tavily() {
    local key="$1"
    local cache_file
    cache_file="$(quota_cache_key "${key}")"

    local cached
    if cached="$(quota_cache_read "${cache_file}")"; then
        echo "${cached}"
        return
    fi

    local response http_code body
    response="$(${CURL_CMD:-curl} -sS -w "\n%{http_code}" \
        "https://api.tavily.com/usage" \
        -H "Authorization: Bearer ${key}" 2>&1)" || {
        echo "error,request failed"
        return
    }

    http_code="$(echo "${response}" | tail -1)"
    body="$(echo "${response}" | sed '$d')"

    if [[ "${http_code}" != "200" ]]; then
        echo "error,HTTP ${http_code}"
        return
    fi

    # Parse JSON with python3 via stdin (safe: no shell interpolation of body)
    local result
    result="$(echo "${body}" | python3 -c "
import json, sys
try:
    d = json.loads(sys.stdin.read())
    used = d.get('key', {}).get('usage', 0)
    limit = d.get('key', {}).get('limit')
    if limit is None:
        limit = d.get('account', {}).get('plan_limit', 0)
    print(f'{used},{limit},')
except Exception as e:
    print(f'error,{e}')
" 2>&1)" || {
        echo "error,parse failed"
        return
    }

    quota_cache_write "${cache_file}" "${result}"
    echo "${result}"
}

quota_brave() {
    local key="$1"
    local cache_file
    cache_file="$(quota_cache_key "${key}")"

    local cached
    if cached="$(quota_cache_read "${cache_file}")"; then
        echo "${cached}"
        return
    fi

    # Lightweight search to get rate limit headers (costs 1 credit)
    local headers
    headers="$(${CURL_CMD:-curl} -sS -D - -o /dev/null \
        "https://api.search.brave.com/res/v1/web/search?q=test&count=1" \
        -H "X-Subscription-Token: ${key}" \
        -H "Accept: application/json" 2>&1)" || {
        echo "error,request failed"
        return
    }

    # Parse X-RateLimit-Remaining: <per_sec>, <per_month>
    # Parse X-RateLimit-Limit: <per_sec>, <per_month>
    # Parse X-RateLimit-Reset: <sec_reset>, <month_reset_sec>
    local remaining limit_header reset_header
    remaining="$(echo "${headers}" | grep -i "^x-ratelimit-remaining:" | head -1 | sed 's/^[^:]*: *//' | tr -d '\r')"
    limit_header="$(echo "${headers}" | grep -i "^x-ratelimit-limit:" | head -1 | sed 's/^[^:]*: *//' | tr -d '\r')"
    reset_header="$(echo "${headers}" | grep -i "^x-ratelimit-reset:" | head -1 | sed 's/^[^:]*: *//' | tr -d '\r')"

    if [[ -z "${remaining}" || -z "${limit_header}" ]]; then
        echo "error,no rate limit headers"
        return
    fi

    # Extract monthly values (second number after comma)
    local month_remaining month_limit month_reset
    month_remaining="$(echo "${remaining}" | awk -F', *' '{print $2}')"
    month_limit="$(echo "${limit_header}" | awk -F', *' '{print $2}')"
    month_reset="$(echo "${reset_header}" | awk -F', *' '{print $2}')"

    local used=$((month_limit - month_remaining))
    local reset_info=""
    if [[ -n "${month_reset}" && "${month_reset}" -gt 0 ]] 2>/dev/null; then
        local days=$((month_reset / 86400))
        local hours=$(((month_reset % 86400) / 3600))
        reset_info="resets in ${days}d ${hours}h"
    fi

    local result="${used},${month_limit},${reset_info}"
    quota_cache_write "${cache_file}" "${result}"
    echo "${result}"
}

# --- Commands ---
cmd_status() {
    local current pool
    current="$(secret_get "${KEY_VAR}")"
    pool="$(secret_get "${POOL_VAR}")"

    if [[ -z "${pool}" ]]; then
        echo "No pool found for ${SERVICE} (${POOL_VAR} is empty)."
        exit 1
    fi

    IFS=',' read -ra keys <<<"${pool}"

    echo "Service: ${SERVICE} (backend: ${BACKEND})"
    echo "Pool: ${#keys[@]} keys"
    echo ""
    for i in "${!keys[@]}"; do
        local marker=" "
        if [[ "${keys[$i]}" == "${current}" ]]; then
            marker=">"
        fi
        echo "  ${marker} [$((i + 1))] $(mask_key "${keys[$i]}")"
    done
    echo ""
    echo "Active: $(mask_key "${current}")"
}

cmd_rotate() {
    local current pool
    current="$(secret_get "${KEY_VAR}")"
    pool="$(secret_get "${POOL_VAR}")"

    if [[ -z "${pool}" ]]; then
        echo "No pool found for ${SERVICE} (${POOL_VAR} is empty)."
        exit 1
    fi

    IFS=',' read -ra keys <<<"${pool}"
    local n=${#keys[@]}

    if [[ ${n} -lt 2 ]]; then
        echo "Only 1 key in ${SERVICE} pool — nothing to rotate to."
        echo "Add more keys with: mcp-key-rotate ${SERVICE} --add NEW_KEY"
        exit 1
    fi

    # Stale pointer or manual edit: treat current_idx=-1 so iteration starts at slot 0.
    local current_idx=-1
    local i
    for i in "${!keys[@]}"; do
        if [[ "${keys[$i]}" == "${current}" ]]; then
            current_idx=$i
            break
        fi
    done

    local next_idx=-1
    local attempt
    for ((attempt = 1; attempt < n; attempt++)); do
        local try_idx=$(((current_idx + attempt) % n))
        local try_key="${keys[${try_idx}]}"
        if health_is_eligible "${try_key}"; then
            next_idx=${try_idx}
            break
        fi
    done

    # All-open fallback: pick the key with the soonest open_until (least-bad).
    local warn_all_open=0
    if [[ ${next_idx} -lt 0 ]]; then
        warn_all_open=1
        local soonest_idx=-1
        local soonest_t=""
        for ((attempt = 1; attempt < n; attempt++)); do
            local try_idx=$(((current_idx + attempt) % n))
            local try_key="${keys[${try_idx}]}"
            local ou
            ou="$(health_open_until "${try_key}")"
            if [[ -z "${soonest_t}" || "${ou}" -lt "${soonest_t}" ]]; then
                soonest_t="${ou}"
                soonest_idx=${try_idx}
            fi
        done
        next_idx=${soonest_idx}
    fi

    local next_key="${keys[${next_idx}]}"
    secret_set "${KEY_VAR}" "${next_key}"

    if [[ ${warn_all_open} -eq 1 ]]; then
        local now delta
        now="$(date +%s)"
        delta=$(($(health_open_until "${next_key}") - now))
        [[ ${delta} -lt 0 ]] && delta=0
        echo "Warning: all other ${SERVICE} keys are in circuit-open state." >&2
        echo "  Picked least-bad key [$((next_idx + 1))] which cools down in ${delta}s." >&2
        echo "  Consider 'mcp-key-rotate ${SERVICE} --add NEW_KEY' or /web-search fallback." >&2
    fi

    echo "Rotated ${SERVICE}: $(mask_key "${current}") -> $(mask_key "${next_key}")"
    echo "Now active: key [$((next_idx + 1))] of ${n} (backend: ${BACKEND})"

    # Auto-sync to mcp-keys.env for mcp-env-inject wrapper
    sync_mcp_keys_env
}

cmd_quota() {
    local current pool
    current="$(secret_get "${KEY_VAR}")"
    pool="$(secret_get "${POOL_VAR}")"

    if [[ -z "${pool}" ]]; then
        echo "No pool found for ${SERVICE} (${POOL_VAR} is empty)."
        exit 1
    fi

    # Resolve quota provider by service name (case dispatch, no bash 4+ needed)
    local service_lower
    service_lower="$(echo "${SERVICE_UPPER}" | tr '[:upper:]' '[:lower:]')"
    local provider=""
    case "${service_lower}" in
        brave) provider="quota_brave" ;;
        tavily) provider="quota_tavily" ;;
    esac
    if [[ -z "${provider}" ]]; then
        echo "No quota provider for service '${SERVICE}'."
        echo "Supported: brave, tavily"
        exit 1
    fi

    IFS=',' read -ra keys <<<"${pool}"

    echo "Service: ${SERVICE} (backend: ${BACKEND})"
    echo "Pool: ${#keys[@]} keys"
    echo ""

    for i in "${!keys[@]}"; do
        local key="${keys[$i]}"
        local marker=" "
        if [[ "${key}" == "${current}" ]]; then
            marker=">"
        fi

        local quota_data
        quota_data="$("${provider}" "${key}")"

        local field1 field2 field3
        IFS=',' read -r field1 field2 field3 <<<"${quota_data}"

        local quota_str
        if [[ "${field1}" == "error" ]]; then
            quota_str="(${field2})"
        else
            local used="${field1}" limit="${field2}" reset="${field3}"
            local remaining=$((limit - used))
            quota_str="${used}/${limit} used (${remaining} remaining)"
            if [[ -n "${reset}" ]]; then
                quota_str="${quota_str}, ${reset}"
            fi
        fi

        echo "  ${marker} [$((i + 1))] $(mask_key "${key}")   ${quota_str}"
    done
    echo ""
}

cmd_mark_bad() {
    local ttl="${1:-${HEALTH_DEFAULT_TTL_SEC}}"
    if ! [[ "${ttl}" =~ ^[0-9]+$ ]]; then
        echo "Error: TTL must be a non-negative integer (seconds). Got: ${ttl}" >&2
        exit 1
    fi

    local current
    current="$(secret_get "${KEY_VAR}")"
    if [[ -z "${current}" ]]; then
        echo "No active key found for ${SERVICE} (${KEY_VAR})." >&2
        exit 1
    fi

    health_mark_open "${current}" "${ttl}" "marked bad via --mark-bad"

    local now_epoch until_epoch
    now_epoch="$(date +%s)"
    until_epoch=$((now_epoch + ttl))
    echo "Marked $(mask_key "${current}") as OPEN for ${ttl}s (backend: ${BACKEND})"
    echo "Recovers at epoch ${until_epoch}"
}

# Like --mark-bad but takes an explicit key arg (ignores backend current).
# Used by auto-rotate-mcp-key.sh to flag the key the MCP server actually used,
# which may have drifted from the backend's current pointer.
cmd_mark_bad_key() {
    local key="$1"
    local ttl="${2:-${HEALTH_DEFAULT_TTL_SEC}}"
    if [[ -z "${key}" ]]; then
        echo "Usage: mcp-key-rotate ${SERVICE} --mark-bad-key KEY [TTL]" >&2
        exit 1
    fi
    if ! [[ "${ttl}" =~ ^[0-9]+$ ]]; then
        echo "Error: TTL must be a non-negative integer (seconds). Got: ${ttl}" >&2
        exit 1
    fi
    health_mark_open "${key}" "${ttl}" "marked bad via --mark-bad-key"
    echo "Marked $(mask_key "${key}") as OPEN for ${ttl}s"
}

# Atomic recovery: mark the failing key OPEN, then ensure backend points to a
# healthy key (no-op if current is already eligible and != failed_key, else
# rotate skipping OPEN keys; least-bad fallback if all are OPEN). Prints the
# resulting active key on the final line as "Active: <key>".
cmd_recover() {
    local failed_key="${1:-}"
    local ttl="${2:-${HEALTH_DEFAULT_TTL_SEC}}"
    if ! [[ "${ttl}" =~ ^[0-9]+$ ]]; then
        echo "Error: TTL must be a non-negative integer (seconds). Got: ${ttl}" >&2
        exit 1
    fi

    local current pool
    current="$(secret_get "${KEY_VAR}")"
    pool="$(secret_get "${POOL_VAR}")"

    if [[ -z "${pool}" ]]; then
        echo "No pool found for ${SERVICE} (${POOL_VAR} is empty)." >&2
        exit 1
    fi

    IFS=',' read -ra keys <<<"${pool}"
    local n=${#keys[@]}

    if [[ -n "${failed_key}" ]]; then
        health_mark_open "${failed_key}" "${ttl}" "marked bad via --recover-from-failure"
    fi

    # Drift fast path: current is already healthy and isn't the failed key.
    # Empty failed_key falls through to rotate (can't prove current is safe).
    if [[ -n "${failed_key}" && -n "${current}" && "${current}" != "${failed_key}" ]] \
        && health_is_eligible "${current}"; then
        echo "No rotation needed ${SERVICE}: current $(mask_key "${current}") is already healthy."
        echo "Now active: key $(mask_key "${current}") of ${n} (backend: ${BACKEND})"
        echo "Active: ${current}"
        return 0
    fi

    local current_idx=-1
    local i
    for i in "${!keys[@]}"; do
        if [[ "${keys[$i]}" == "${current}" ]]; then
            current_idx=$i
            break
        fi
    done

    # Walk all N slots so that when failed_key is empty the loop can wrap back
    # to current; skip any slot that equals failed_key.
    local next_idx=-1
    local attempt
    for ((attempt = 1; attempt <= n; attempt++)); do
        local try_idx=$(((current_idx + attempt) % n))
        local try_key="${keys[${try_idx}]}"
        if [[ -n "${failed_key}" && "${try_key}" == "${failed_key}" ]]; then
            continue
        fi
        if health_is_eligible "${try_key}"; then
            next_idx=${try_idx}
            break
        fi
    done

    # All-open fallback: pick soonest-to-recover, still excluding failed_key.
    local warn_all_open=0
    if [[ ${next_idx} -lt 0 ]]; then
        warn_all_open=1
        local soonest_idx=-1
        local soonest_t=""
        for ((attempt = 1; attempt <= n; attempt++)); do
            local try_idx=$(((current_idx + attempt) % n))
            local try_key="${keys[${try_idx}]}"
            if [[ -n "${failed_key}" && "${try_key}" == "${failed_key}" ]]; then
                continue
            fi
            local ou
            ou="$(health_open_until "${try_key}")"
            if [[ -z "${soonest_t}" || "${ou}" -lt "${soonest_t}" ]]; then
                soonest_t="${ou}"
                soonest_idx=${try_idx}
            fi
        done
        if [[ ${soonest_idx} -lt 0 ]]; then
            echo "Error: pool contains only the failing key (${SERVICE})." >&2
            exit 1
        fi
        next_idx=${soonest_idx}
    fi

    local next_key="${keys[${next_idx}]}"
    secret_set "${KEY_VAR}" "${next_key}"

    if [[ ${warn_all_open} -eq 1 ]]; then
        local now delta
        now="$(date +%s)"
        delta=$(($(health_open_until "${next_key}") - now))
        [[ ${delta} -lt 0 ]] && delta=0
        echo "Warning: all eligible ${SERVICE} keys are in circuit-open state." >&2
        echo "  Picked least-bad key [$((next_idx + 1))] which cools down in ${delta}s." >&2
    fi

    echo "Rotated ${SERVICE}: $(mask_key "${current}") -> $(mask_key "${next_key}")"
    echo "Now active: key [$((next_idx + 1))] of ${n} (backend: ${BACKEND})"
    sync_mcp_keys_env
    echo "Active: ${next_key}"
}

cmd_mark_good() {
    local current
    current="$(secret_get "${KEY_VAR}")"
    if [[ -z "${current}" ]]; then
        echo "No active key found for ${SERVICE} (${KEY_VAR})." >&2
        exit 1
    fi
    health_mark_closed "${current}"
    echo "Marked $(mask_key "${current}") as CLOSED (circuit closed, backend: ${BACKEND})"
}

cmd_reset_health() {
    health_reset
    echo "Reset health state for ${SERVICE} ($(health_file))"
}

cmd_health() {
    local current pool
    current="$(secret_get "${KEY_VAR}")"
    pool="$(secret_get "${POOL_VAR}")"

    if [[ -z "${pool}" ]]; then
        echo "No pool found for ${SERVICE} (${POOL_VAR} is empty)."
        exit 1
    fi

    IFS=',' read -ra keys <<<"${pool}"
    local now
    now="$(date +%s)"

    echo "Service: ${SERVICE} (backend: ${BACKEND})"
    echo "Health file: $(health_file)"
    echo "Pool: ${#keys[@]} keys"
    echo ""

    local i
    for i in "${!keys[@]}"; do
        local key="${keys[$i]}"
        local marker=" "
        if [[ "${key}" == "${current}" ]]; then
            marker=">"
        fi

        local state ou ec status_str
        state="$(health_state "${key}")"
        ou="$(health_open_until "${key}")"
        ec="$(_health_read_field "${key}" "ejection_count")"
        ec="${ec:-0}"

        if [[ "${state}" == "open" && "${ou}" -gt "${now}" ]]; then
            status_str="OPEN (cools in $((ou - now))s, ejections=${ec})"
        elif [[ "${state}" == "open" ]]; then
            status_str="HALF_OPEN (ready to probe, ejections=${ec})"
        else
            status_str="CLOSED (ejections=${ec})"
        fi

        echo "  ${marker} [$((i + 1))] $(mask_key "${key}")   ${status_str}"
    done
    echo ""
}

cmd_add() {
    local new_key="$1"
    local pool
    pool="$(secret_get "${POOL_VAR}")"

    if [[ -z "${pool}" ]]; then
        # Initialize pool with just the new key and set it as active
        secret_set "${POOL_VAR}" "${new_key}"
        secret_set "${KEY_VAR}" "${new_key}"
        echo "Initialized ${SERVICE} pool with $(mask_key "${new_key}") (backend: ${BACKEND})"
        return
    fi

    # Check for duplicates
    IFS=',' read -ra keys <<<"${pool}"
    for k in "${keys[@]}"; do
        if [[ "${k}" == "${new_key}" ]]; then
            echo "Key $(mask_key "${new_key}") already in ${SERVICE} pool."
            exit 1
        fi
    done

    secret_set "${POOL_VAR}" "${pool},${new_key}"
    echo "Added $(mask_key "${new_key}") to ${SERVICE} pool (now $((${#keys[@]} + 1)) keys, backend: ${BACKEND})"
}

# --- Main ---
case "${1:-}" in
    --status | -s)
        cmd_status
        ;;
    --quota | -q)
        cmd_quota
        ;;
    --health)
        cmd_health
        ;;
    --mark-bad)
        cmd_mark_bad "${2:-}"
        ;;
    --mark-bad-key)
        cmd_mark_bad_key "${2:-}" "${3:-}"
        ;;
    --recover-from-failure)
        cmd_recover "${2:-}" "${3:-}"
        ;;
    --mark-good)
        cmd_mark_good
        ;;
    --reset-health)
        cmd_reset_health
        ;;
    --add | -a)
        if [[ -z "${2:-}" ]]; then
            echo "Usage: mcp-key-rotate ${SERVICE} --add KEY"
            exit 1
        fi
        cmd_add "$2"
        ;;
    --sync)
        cmd_sync
        ;;
    --help | -h)
        cat <<EOF
Usage: mcp-key-rotate <service> [command]

Commands:
  (no args)         Rotate to next HEALTHY key (skips OPEN keys in pool)
  --status, -s      Show current key and pool
  --health          Show circuit state (CLOSED / OPEN / HALF_OPEN) per key
  --quota, -q       Show per-key credit usage (live API check)
  --mark-bad [TTL]              Mark current (backend) key OPEN for TTL seconds
                                (default: ${HEALTH_DEFAULT_TTL_SEC})
  --mark-bad-key KEY [TTL]      Mark an explicitly-provided key OPEN (used by
                                auto-rotate hook when backend current has drifted
                                away from the key the MCP server actually used)
  --recover-from-failure KEY [TTL]
                                Atomic recovery: mark KEY bad, then ensure backend
                                points to a healthy key (no-op if current is already
                                healthy and != KEY; otherwise rotate). Prints the
                                active key on the final line (prefixed "Active: ").
  --mark-good                   Mark current key CLOSED (clear circuit for current)
  --reset-health                Delete the service's entire health state file
  --add, -a KEY     Add a new key to the pool
  --sync            Sync active key to ~/.claude/mcp-keys.env
  --help, -h        Show this help

Services: brave, tavily (or any MCP service with {SERVICE}_API_KEY + {SERVICE}_API_KEY_POOL)
Backends: doppler (auto-detected), dotenv (.env file)
Overrides:
  KEY_ROTATE_BACKEND=doppler|dotenv
  MCP_KEY_HEALTH_DIR=<dir>                (default: ~/.claude/state)
  MCP_KEY_HEALTH_DEFAULT_TTL_SEC=<int>    (default: 3600)
EOF
        ;;
    "")
        cmd_rotate
        ;;
    *)
        echo "Unknown option: $1"
        echo "Run mcp-key-rotate ${SERVICE} --help for usage."
        exit 1
        ;;
esac

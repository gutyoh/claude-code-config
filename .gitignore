# ============================================================================
# Claude Code Portable Configuration - .gitignore
# ============================================================================
# This gitignore is designed for a Claude Code configuration repository
# that contains portable MCP servers, skills, agents, and hooks.
#
# Philosophy:
#   - Commit shared configs (.mcp.json, CLAUDE.md, .claude/skills/, etc.)
#   - Ignore personal/local settings and sensitive data
# ============================================================================

# ----------------------------------------------------------------------------
# CLAUDE CODE - LOCAL/PERSONAL FILES (Never commit these)
# ----------------------------------------------------------------------------

# Personal project preferences (auto-created, meant to be local-only)
CLAUDE.local.md
**/CLAUDE.local.md

# Local settings overrides (personal preferences per developer)
.claude/settings.local.json
**/.claude/settings.local.json
**/.claude/*.local.*

# Skill eval workspaces (ephemeral test artifacts, not source code)
*-workspace/

# Claude Code runtime/cache directories
.claude/cache/
.claude/history/
.claude/state/
.claude/logs/
**/.claude/cache/
**/.claude/history/
**/.claude/state/
**/.claude/logs/

# Claude Code session files
.claude-session
.claude-session.*

# Symlinks created by setup scripts (machine-specific, should not be tracked)
# These are self-referential symlinks that can be accidentally created
.claude/agents/agents
.claude/skills/skills
.claude/hooks/hooks

# ----------------------------------------------------------------------------
# MCP SERVERS - SENSITIVE DATA (API keys, tokens, secrets)
# ----------------------------------------------------------------------------

# Environment files with secrets
.env
.envrc
.env.local
.env.*.local
.env.development.local
.env.test.local
.env.production.local

# API keys file (if someone creates one)
api-keys.json
secrets.json
credentials.json
.secrets
*.secret
*.secrets

# SSH keys (should never be in repo)
*.pem
*.key
id_rsa*
id_ed25519*

# ----------------------------------------------------------------------------
# NODE.JS / NPM (for npx-based MCP servers)
# ----------------------------------------------------------------------------

node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
package-lock.json
yarn.lock
pnpm-lock.yaml

# Optional npm cache directory
.npm

# Optional eslint cache
.eslintcache

# ----------------------------------------------------------------------------
# PYTHON (for Python-based MCP servers like mcp-server-fetch)
# ----------------------------------------------------------------------------

# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
venv/
ENV/
env/
.venv/
.python-version

# pip
pip-log.txt
pip-delete-this-directory.txt

# Poetry
poetry.lock

# uv package manager
uv.lock
.uv/

# ----------------------------------------------------------------------------
# OPERATING SYSTEM FILES
# ----------------------------------------------------------------------------

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# Linux
*~
.directory
.Trash-*

# ----------------------------------------------------------------------------
# EDITORS & IDEs
# ----------------------------------------------------------------------------

# VS Code (keep .vscode/settings.json if you want shared settings)
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# JetBrains IDEs
.idea/
*.iml
*.ipr
*.iws

# Vim
*.swp
*.swo
*.swn
*~

# Emacs
*~
\#*\#
/.emacs.desktop
/.emacs.desktop.lock
*.elc

# Sublime Text
*.sublime-workspace
*.sublime-project

# ----------------------------------------------------------------------------
# BUILD ARTIFACTS & LOGS
# ----------------------------------------------------------------------------

# Build directories
dist/
build/
out/
target/

# Logs
logs/
*.log

# Coverage reports (if testing MCP servers)
coverage/
.coverage
htmlcov/
.nyc_output/

# ----------------------------------------------------------------------------
# DOCKER (if containerizing MCP servers)
# ----------------------------------------------------------------------------

# Docker volumes/data (local dev data)
docker-data/
.docker/

# ----------------------------------------------------------------------------
# MISCELLANEOUS
# ----------------------------------------------------------------------------

# Temporary files
tmp/
temp/
*.tmp
*.temp
*.bak
*.backup

# Archives (probably shouldn't be in version control)
*.zip
*.tar
*.tar.gz
*.rar
*.7z

# Database files (local dev databases)
*.sqlite
*.sqlite3
*.db

# Test outputs
test-results/
playwright-report/
